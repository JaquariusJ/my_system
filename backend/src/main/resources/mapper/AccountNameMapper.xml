<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.assetmanager.mapper.AccountNameMapper">
    <resultMap id="AccountNameResultMap" type="com.example.assetmanager.domain.AccountName">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="identifier" property="identifier"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="remark" property="remark"/>
        <result column="active" property="active"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findAll" resultMap="AccountNameResultMap">
        select *
        from account_names
        order by created_at desc, id desc
    </select>

    <select id="findById" resultMap="AccountNameResultMap">
        select *
        from account_names
        where id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into account_names (name, identifier, sort_order, remark, active)
        values (#{name}, #{identifier}, 100, #{remark}, true)
    </insert>

    <update id="update">
        update account_names
        set name = #{name},
            identifier = #{identifier},
            remark = #{remark},
            active = true
        where id = #{id}
    </update>

    <select id="countAccountsByName" resultType="int">
        select count(*)
        from accounts
        where name = #{name}
    </select>

    <update id="updateAccountName">
        update accounts
        set name = #{newName}
        where name = #{oldName}
    </update>

    <delete id="delete">
        delete from account_names
        where id = #{id}
    </delete>
</mapper>
